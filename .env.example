# ===== NoteShare Konfigürasyon =====
# Bu dosyayı .env olarak kopyala ve değerleri doldur.

# Ortam: production (canlı) veya development (local)
APP_ENV=production
APP_URL=https://senin-domain.com

# Veritabanı
DB_HOST=localhost
DB_NAME=notdeposu
DB_USER=noteshare_user
DB_PASS=BURAYA_GUCLU_SIFRE

# Anthropic Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXX

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXXX
GOOGLE_REDIRECT_URI=https://senin-domain.com/google-login-calistir.php

# Facebook OAuth (https://developers.facebook.com)
FB_APP_ID=1234567890
FB_APP_SECRET=abcdef1234567890abcdef1234567890
FB_REDIRECT_URI=https://senin-domain.com/fb-login-calistir.php
